---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import { getUi, getProfile, getProjects } from '../i18n/content';
import { ROUTES } from '../i18n/routes';
import { getFeaturedTags } from '../i18n/skills';

const lang = 'fr' as const;
const ui = getUi(lang);
const profile = getProfile(lang);
const projects = getProjects(lang);

const featuredTags = getFeaturedTags(profile.parcours, projects as { tags: string[] }[]);
---

<Layout lang={lang} pageKey="home" description={ui.meta.homeDescription}>
  <Hero
    greeting={ui.home.greeting}
    name={profile.nom}
    title={profile.titre}
    description={profile.accroche}
    projectsHref={ROUTES.projets[lang]}
    projectsLabel={ui.home.viewProjects}
    blogHref={ROUTES.posts[lang]}
    blogLabel={ui.home.readBlog}
    skillsLabel={ui.home.skillsLabel}
    tags={featuredTags}
  />
</Layout>
