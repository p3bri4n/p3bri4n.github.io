---
import Layout from '../../layouts/Layout.astro';
import Avatar from '../../components/Avatar.astro';
import KpiStats from '../../components/KpiStats.astro';
import SkillTiers from '../../components/SkillTiers.astro';
import Timeline from '../../components/Timeline.astro';
import { getProfile, getProjects, getUi } from '../../i18n/content';
import { computeSkills, computeStats, groupSkillsByTier } from '../../i18n/skills';
import { ROUTES } from '../../i18n/routes';

const lang = 'fr' as const;
const profile = getProfile(lang);
const projects = getProjects(lang);
const ui = getUi(lang);
const cvUrl = ROUTES.cv[lang];

const skills = groupSkillsByTier(
  computeSkills([...profile.formation, ...profile.parcours], projects as { tags: string[] }[], ui.skillCategories),
  ui.skillTiers
);
const stats = computeStats(profile, 'ans');
---

<Layout lang={lang} pageKey="about" title={ui.nav.about} description={ui.meta.aboutDescription} wide>
  <section class="flex flex-col items-center text-center sm:flex-row sm:items-center sm:text-left gap-6 mb-10">
    <Avatar nom={profile.nom} image={profile.avatar} size={96} />
    <div>
      <h1 class="text-3xl font-bold tracking-tight mb-1">{profile.nom}</h1>
      <p class="text-lg text-sky-600 dark:text-sky-400 mb-4">{profile.titre}</p>
      <a
        href={cvUrl}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 px-4 py-2 rounded-md border border-slate-300 dark:border-slate-700 font-medium text-sm hover:border-sky-400 dark:hover:border-sky-600 transition-colors"
      >
        <svg
          class="w-4 h-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
          <polyline points="7 10 12 15 17 10"></polyline>
          <line x1="12" y1="15" x2="12" y2="3"></line>
        </svg>
        {ui.about.downloadCv}
      </a>
    </div>
  </section>

  <section class="mb-10 text-center sm:text-left">
    <p class="text-slate-600 dark:text-slate-300 whitespace-pre-line">{profile.bio}</p>
  </section>

  <section class="mb-14">
    <KpiStats stats={stats} />
  </section>

  <section class="mb-14">
    <h2 class="text-xl font-semibold mb-6">{ui.about.objectifsTitle}</h2>
    <ul class="glass-panel rounded-lg p-6 space-y-3 list-disc list-inside text-slate-600 dark:text-slate-300">
      {profile.objectifs.map((objectif: string) => (
        <li>{objectif}</li>
      ))}
    </ul>
  </section>

  <section class="mb-14">
    <h2 class="text-xl font-semibold mb-6">{ui.about.skillsTitle}</h2>
    <SkillTiers tiers={skills} />
  </section>

  <section class="mb-14">
    <h2 class="text-xl font-semibold mb-6">{ui.about.experienceTitle}</h2>
    <Timeline entries={profile.parcours} />
  </section>

  <section>
    <h2 class="text-xl font-semibold mb-6">{ui.about.formationTitle}</h2>
    <Timeline entries={profile.formation} />
  </section>
</Layout>
