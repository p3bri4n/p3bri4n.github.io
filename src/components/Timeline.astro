---
import { tagValue } from '../i18n/skills';

interface Entry {
  periode: string;
  titre: string;
  lieu: string;
  description: string;
  competences?: string[];
}

interface Props {
  entries: Entry[];
}

const { entries } = Astro.props;
---

<ol class="space-y-6 border-l border-slate-200 dark:border-slate-800 pl-6">
  {entries.map((entry) => (
    <li class="relative">
      <span class="absolute -left-[1.9rem] top-1.5 h-2.5 w-2.5 rounded-full bg-sky-500"></span>
      <div class="glass-panel rounded-lg p-4">
        <p class="text-sm text-slate-500 dark:text-slate-400">{entry.periode}</p>
        <h3 class="font-semibold">{entry.titre}</h3>
        <p class="text-sm text-slate-500 dark:text-slate-400 mb-1">{entry.lieu}</p>
        <p class="text-sm mb-2">{entry.description}</p>
        {entry.competences && entry.competences.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {entry.competences.map((competence) => (
              <span class="glass-tag px-2.5 py-1 text-xs rounded-full">
                {tagValue(competence)}
              </span>
            ))}
          </div>
        )}
      </div>
    </li>
  ))}
</ol>
