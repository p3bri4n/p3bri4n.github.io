---
import type { SkillGroupData } from '../i18n/skills';

interface Props {
  groups: SkillGroupData[];
  showAllLabel: string;
  showFeaturedLabel: string;
}

const { groups, showAllLabel, showFeaturedLabel } = Astro.props;
const hasExtra = groups.some((group) => group.items.some((item) => !item.featured));
---

<div class="grid gap-6 sm:grid-cols-2">
  {groups.map((group) => (
    <div class="glass-panel rounded-lg p-4">
      <h3 class="font-semibold mb-2">{group.categorie}</h3>
      <div class="flex flex-wrap gap-2">
        {group.items.map((item) => (
          <span
            class={`glass-tag px-2.5 py-1 text-xs rounded-full${item.featured ? '' : ' skill-extra hidden'}`}
          >
            {item.value}
          </span>
        ))}
      </div>
    </div>
  ))}
</div>
{hasExtra && (
  <button
    id="skills-toggle"
    type="button"
    data-expanded="false"
    data-show-all={showAllLabel}
    data-show-featured={showFeaturedLabel}
    aria-label={showAllLabel}
    class="mt-4 p-1.5 rounded-full border border-sky-600/40 dark:border-sky-400/40 text-sky-600 dark:text-sky-400 hover:bg-sky-600/10 dark:hover:bg-sky-400/10 hover:border-sky-600 dark:hover:border-sky-400 transition-colors"
  >
    <svg id="skills-toggle-down" class="w-6 h-6 block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M6 9l6 6 6-6"></path>
    </svg>
    <svg id="skills-toggle-up" class="w-6 h-6 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M18 15l-6-6-6 6"></path>
    </svg>
  </button>
)}

<script>
  document.addEventListener('astro:page-load', () => {
    const button = document.getElementById('skills-toggle');
    const iconDown = document.getElementById('skills-toggle-down');
    const iconUp = document.getElementById('skills-toggle-up');
    button?.addEventListener('click', () => {
      const expanded = button.dataset.expanded === 'true';
      document.querySelectorAll<HTMLElement>('.skill-extra').forEach((el) => {
        el.classList.toggle('hidden', expanded);
      });
      button.dataset.expanded = String(!expanded);
      button.setAttribute('aria-label', expanded ? button.dataset.showAll! : button.dataset.showFeatured!);
      iconDown?.classList.toggle('hidden', !expanded);
      iconUp?.classList.toggle('hidden', expanded);
    });
  });
</script>
