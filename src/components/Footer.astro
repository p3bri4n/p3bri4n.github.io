---
import { site } from '../config';

const year = new Date().getFullYear();
---

<footer class="border-t border-slate-200 dark:border-slate-800 bg-white/70 dark:bg-slate-900/70 backdrop-blur-md mt-10">
  <div class="max-w-3xl mx-auto px-4 py-6 text-sm text-slate-500 dark:text-slate-400">
    <p>&copy; {year} {site.name}</p>
  </div>
</footer>
