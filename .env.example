# Copie ce fichier en .env et adapte les valeurs.
# Astro n'expose au client que les variables préfixées par PUBLIC_.

PUBLIC_SITE_URL=https://pebrian.fr
PUBLIC_SITE_NAME="pebrian.fr/"
PUBLIC_CONTACT_EMAIL=contact@example.com
# Optionnel : affiché (rendu en image via canvas, anti-scraping) sur le CV généré (/cv, /en/cv).
PUBLIC_CONTACT_PHONE=
PUBLIC_GITHUB_URL=https://github.com/p3bri4n
PUBLIC_LINKEDIN_URL=
PUBLIC_TWITTER_URL=

# Easter egg jouable depuis le logo du header (survoler pendant le glitch
# périodique). Un seul actif à la fois ; clés disponibles : src/games/.
PUBLIC_EASTER_EGG_GAME=title-guardian
